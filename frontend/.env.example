# Copy to .env in this directory (Create React App reads REACT_APP_* from .env).
# cp .env.example .env

# Backend base URL (no trailing slash). Must match what the browser uses for API calls.
#
# Local development:
REACT_APP_BACKEND_URL=http://127.0.0.1:8000
#
# Production (same-origin via Nginx — UI and /api on one host):
# REACT_APP_BACKEND_URL=https://fleet.gtiholding.com

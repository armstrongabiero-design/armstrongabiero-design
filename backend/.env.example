# =============================================================================
# GTI Fleet — backend environment (copy to .env on the app server)
# =============================================================================
#
#   cp .env.example .env
#   chmod 600 .env
#
# Edit every REPLACE_* value, then restart: sudo systemctl restart fleet-api
#
# Deploy host: 192.168.135.21 (fleet-app-01), app root: /home/fleet/app
# MongoDB: replica set rs0 @ 192.168.135.22:27017, 192.168.135.23:27017
#
# Public URL (must match Nginx + frontend build REACT_APP_BACKEND_URL):
#   Phase 1 — before DNS/TLS:  http://192.168.135.21
#   Phase 2 — production:      https://fleet.gtiholding.com
#
# Same-origin (recommended): Nginx serves React at / and proxies /api → FastAPI.
# Then REACT_APP_BACKEND_URL, CORS_ORIGINS, and FRONTEND_URL are all:
#   https://fleet.gtiholding.com
# (scheme + host only — no trailing slash, no /api path on CORS/FRONTEND_URL).
# =============================================================================

# --- Required: MongoDB ---
# fleetapp user (Part D2). URL-encode password: / → %2F, ! → %21, @ → %40
MONGO_URL=mongodb://fleetapp:Jrfleets%2F0772%21GTI@192.168.135.22:27017,192.168.135.23:27017/fleet_management?replicaSet=rs0&authSource=fleet_management
DB_NAME=fleet_management

# --- Required: security ---
# Generate: python3.11 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<python3 -c "import secrets; print(secrets.token_hex(32))">

ENVIRONMENT=production

# --- Required in production: browser / email origins ---
# Phase 1 (pre-DNS):
CORS_ORIGINS=http://192.168.135.21
FRONTEND_URL=http://192.168.135.21
# Phase 2 (after DNS + HTTPS) — comment Phase 1 lines above and use:
# CORS_ORIGINS=https://fleet.gtiholding.com
# FRONTEND_URL=https://fleet.gtiholding.com

# --- First admin (one-time POST /api/auth/bootstrap with header X-Bootstrap-Token) ---
# Generate: python3.11 -c "import secrets; print(secrets.token_urlsafe(32))"
BOOTSTRAP_TOKEN=REPLACED_BOOTSTRAP_SECRET

# --- Email (password reset / notifications; optional but recommended in prod) ---
RESEND_API_KEY=re_V4RDq7Uw_MzRVG7aYTKdfCAs8fL6h13PT
SENDER_EMAIL=noreply@alerts.jrfleetsolutions.com

# --- Optional: AI features (leave empty to disable) ---
# EMERGENT_LLM_KEY=

# =============================================================================
# Local development only (do not use on fleet-app-01)
# =============================================================================
# Quick start: cp .env.local.example .env  &&  docker compose up -d  (repo root)
#
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=fleet_management
JWT_SECRET_KEY=replace-with-a-long-random-secret-for-local-dev-only
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
BOOTSTRAP_TOKEN=local-bootstrap-secret-change-me
#
# Local app → remote DC MongoDB (VPN/tunnel; not recommended for day-to-day dev):
# MONGO_URL=mongodb://fleetapp:REPLACE_URL_ENCODED_PASSWORD@192.168.135.22:27017/fleet_management?authSource=fleet_management&directConnection=true

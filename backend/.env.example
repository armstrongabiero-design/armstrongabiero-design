# Copy to .env in this directory (backend loads it automatically).
# cp .env.example .env

# Required: MongoDB connection (local Docker: docker compose up -d in repo root)
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=fleet_management

# Required for signing JWTs. Use a long random string (32+ chars). Example:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret-for-local-dev-only

# development | production
ENVIRONMENT=development

# Comma-separated browser origins allowed to call the API (with credentials).
# Defaults to localhost:3000 if unset in development.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Used in password-reset emails (optional locally)
FRONTEND_URL=http://localhost:3000

# One-time first admin: must match server env; send as X-Bootstrap-Token on POST /api/auth/bootstrap
# BOOTSTRAP_TOKEN=your-bootstrap-secret-here

# Email (optional; forgot-password / OTP)
# RESEND_API_KEY=
# SENDER_EMAIL=onboarding@resend.dev
